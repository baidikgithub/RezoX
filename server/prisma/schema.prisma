datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  agent
  buyer
  user
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(buyer)
  phone         String?
  avatar        String?
  bio           String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  listings      Listing[]
  favorites     Favorite[]
  bookings      Booking[]
  reviews       Review[]
  notifications Notification[]
  conversations Conversation[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Listing {
  id            Int        @id @default(autoincrement())
  title         String?
  description   String?
  location      String?
  address       String?
  city          String?
  state         String?
  property_type String?    @default("Apartment")
  status        String?    @default("available")
  price         Decimal?
  total_sqft    Decimal?
  bath          Int?
  bhk           Int?
  latitude      Float?
  longitude     Float?
  images        String[]   @default([])
  amenities     String[]   @default([])
  agent_id      Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  agent         User?      @relation(fields: [agent_id], references: [id], onDelete: SetNull)
  favorites     Favorite[]
  bookings      Booking[]
  reviews       Review[]

  @@index([location])
  @@index([price])
  @@index([bhk])
  @@map("listings")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  user_id    Int
  listing_id Int
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([user_id, listing_id])
  @@map("favorites")
}

model Booking {
  id         Int      @id @default(autoincrement())
  user_id    Int
  listing_id Int
  visit_at   DateTime
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Review {
  id         Int      @id @default(autoincrement())
  user_id    Int
  listing_id Int
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([user_id, listing_id])
  @@map("reviews")
}

model Notification {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String
  body       String?
  type       String?   @default("info")
  read_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Conversation {
  id         String    @id @db.Uuid
  user_id    Int?
  title      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  user       User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages   Message[]

  @@map("conversations")
}

model Message {
  id              String       @id @db.Uuid
  conversation_id String       @db.Uuid
  role            String
  content         String
  model           String?
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@map("password_reset_tokens")
}
