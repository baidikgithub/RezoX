datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Listing {
  id         Int      @id @default(autoincrement())
  title      String?
  location   String?
  price      Float?
  total_sqft Float?
  bath       Int?
  bhk        Int?
  images     String[] @default([])
  amenities  String[] @default([])
  createdAt  DateTime @default(now())

  @@index([location])
  @@map("listings")
}
